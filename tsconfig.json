{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types", "@types/bun"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src", "portal-room/src", "test"]
}
